{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/api/flowai", "dest": "/api/flowai.js" },
    { "src": "/features", "dest": "/pages/features.html" },
    { "src": "/pricing", "dest": "/pages/pricing.html" },
    { "src": "/blog", "dest": "/pages/blog.html" },
    { "src": "/contact", "dest": "/pages/contact.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
